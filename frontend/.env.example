# ===================================================
# Digital HQ — Frontend Environment Variables
# ===================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# Backend API URL (dev: http://localhost:8000, prod: your Render URL)
VITE_API_URL=http://localhost:8000

# App environment
VITE_APP_ENV=development

# Optional: OpenAI API Key (for real ARIA AI responses)
# VITE_OPENAI_API_KEY=sk-...
